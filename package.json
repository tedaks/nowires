{
  "name": "nowires",
  "private": true,
  "workspaces": ["apps/*"],
  "scripts": {
    "dev:web": "npm --workspace apps/web run dev",
    "dev:api": "cd apps/api && python3 -m uvicorn app.main:app --host 0.0.0.0 --port 8000",
    "build:web": "npm --workspace apps/web run build",
    "typecheck": "npm --workspace apps/web run typecheck",
    "lint:api": "cd apps/api && ruff check . && ruff format --check .",
    "lint": "npm --workspace apps/web run lint && npm run lint:api"
  }
}
